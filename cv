<script>
// PARTICLES
(function(){
  const canvas = document.getElementById('particles-canvas');
  const ctx = canvas.getContext('2d');
  let W = canvas.width = window.innerWidth;
  let H = canvas.height = window.innerHeight;
  let mx = W/2, my = H/2;

  window.addEventListener('resize', function(){
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  });
  window.addEventListener('mousemove', function(e){ mx = e.clientX; my = e.clientY; });

  var COLORS = ['200,184,255','139,224,196','240,194,127'];
  var pts = [];
  for(var i=0;i<80;i++){
    pts.push({
      x:Math.random()*window.innerWidth,
      y:Math.random()*window.innerHeight,
      vx:(Math.random()-0.5)*0.22,
      vy:(Math.random()-0.5)*0.22,
      r:Math.random()*1.3+0.3,
      life:Math.random(),
      decay:Math.random()*0.002+0.001,
      col:COLORS[Math.floor(Math.random()*COLORS.length)]
    });
  }

  function tick(){
    ctx.clearRect(0,0,W,H);
    for(var i=0;i<pts.length;i++){
      var p=pts[i];
      p.x+=p.vx+(mx/W-0.5)*0.12;
      p.y+=p.vy+(my/H-0.5)*0.12;
      p.life-=p.decay;
      if(p.life<=0||p.x<-20||p.x>W+20||p.y<-20||p.y>H+20){
        p.x=Math.random()*W; p.y=Math.random()*H; p.life=1;
      }
      ctx.globalAlpha=p.life*0.5;
      ctx.fillStyle='rgb('+p.col+')';
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
      for(var j=i+1;j<pts.length;j++){
        var q=pts[j];
        var dx=p.x-q.x,dy=p.y-q.y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<85){
          ctx.globalAlpha=(1-d/85)*0.045;
          ctx.strokeStyle='rgb('+p.col+')';
          ctx.lineWidth=0.4;
          ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);ctx.stroke();
        }
      }
    }
    ctx.globalAlpha=1;
    requestAnimationFrame(tick);
  }
  tick();
})();

// NAV
(function(){
  var nav=document.getElementById('nav');
  window.addEventListener('scroll',function(){
    nav.classList.toggle('scrolled',window.scrollY>50);
  },{passive:true});
})();

// SCROLL REVEAL
(function(){
  var els=document.querySelectorAll('.reveal');
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting) e.target.classList.add('in');
    });
  },{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
  els.forEach(function(el){io.observe(el);});
})();
</script>

